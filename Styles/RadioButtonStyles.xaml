<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ═══════════════════════════════════════════════════════════════
         RADIOBUTTON STYLES — Themed
         Drop-in replacement for default WPF RadioButton.
         ═══════════════════════════════════════════════════════════════ -->

    <Style TargetType="{x:Type RadioButton}">
        <Setter Property="Foreground"       Value="{DynamicResource Theme.Brush.Text.Primary}"/>
        <Setter Property="Background"       Value="{DynamicResource Theme.Brush.Surface.Dark}"/>
        <Setter Property="BorderBrush"      Value="{DynamicResource Theme.Brush.Border.Default}"/>
        <Setter Property="BorderThickness"  Value="{DynamicResource Theme.BorderThickness.Heavy}"/>
        <Setter Property="FontSize"         Value="{DynamicResource Theme.Font.Size.Body}"/>
        <Setter Property="FontFamily"       Value="{DynamicResource Theme.Font.Family}"/>
        <Setter Property="Padding"          Value="8,0,0,0"/>
        <Setter Property="VerticalContentAlignment" Value="Center"/>
        <Setter Property="Cursor"           Value="Hand"/>
        <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
        <Setter Property="SnapsToDevicePixels" Value="True"/>

        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type RadioButton}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="20"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Border x:Name="RadioBorder"
                                Grid.Column="0"
                                Width="18" Height="18"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="{DynamicResource Theme.Radius.Round}"
                                SnapsToDevicePixels="True">

                            <Ellipse x:Name="RadioDot"
                                     Width="8" Height="8"
                                     Fill="{DynamicResource Theme.Brush.Accent.Base}"
                                     HorizontalAlignment="Center"
                                     VerticalAlignment="Center"
                                     Visibility="Collapsed"/>
                        </Border>

                        <ContentPresenter
                            Grid.Column="1"
                            Margin="{TemplateBinding Padding}"
                            VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                            RecognizesAccessKey="True"/>
                    </Grid>

                    <ControlTemplate.Triggers>
                        <Trigger Property="IsChecked" Value="True">
                            <Setter TargetName="RadioBorder" Property="BorderBrush"
                                    Value="{DynamicResource Theme.Brush.Accent.Base}"/>
                            <Setter TargetName="RadioDot" Property="Visibility"
                                    Value="Visible"/>
                        </Trigger>

                        <MultiTrigger>
                            <MultiTrigger.Conditions>
                                <Condition Property="IsMouseOver" Value="True"/>
                                <Condition Property="IsChecked"   Value="False"/>
                            </MultiTrigger.Conditions>
                            <Setter TargetName="RadioBorder" Property="BorderBrush"
                                    Value="{DynamicResource Theme.Brush.Border.Hover}"/>
                            <Setter TargetName="RadioBorder" Property="Background"
                                    Value="{DynamicResource Theme.Brush.HoverOverlay}"/>
                        </MultiTrigger>

                        <MultiTrigger>
                            <MultiTrigger.Conditions>
                                <Condition Property="IsMouseOver" Value="True"/>
                                <Condition Property="IsChecked"   Value="True"/>
                            </MultiTrigger.Conditions>
                            <Setter TargetName="RadioBorder" Property="BorderBrush"
                                    Value="{DynamicResource Theme.Brush.Accent.Hover}"/>
                            <Setter TargetName="RadioDot" Property="Fill"
                                    Value="{DynamicResource Theme.Brush.Accent.Hover}"/>
                        </MultiTrigger>

                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="RadioBorder" Property="Background"
                                    Value="{DynamicResource Theme.Brush.Border.Subtle}"/>
                            <Setter TargetName="RadioBorder" Property="BorderBrush"
                                    Value="{DynamicResource Theme.Brush.Border.Subtle}"/>
                            <Setter Property="Foreground"
                                    Value="{DynamicResource Theme.Brush.Text.Muted}"/>
                        </Trigger>

                        <Trigger Property="IsFocused" Value="True">
                            <Setter TargetName="RadioBorder" Property="BorderBrush"
                                    Value="{DynamicResource Theme.Brush.Accent.Base}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

</ResourceDictionary>
