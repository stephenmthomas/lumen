<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ═══════════════════════════════════════════════════════════════
         CHECKBOX STYLES — Themed
         Drop-in replacement for default WPF CheckBox.
         ═══════════════════════════════════════════════════════════════ -->

    <Style TargetType="{x:Type CheckBox}">
        <Setter Property="Foreground"       Value="{DynamicResource Theme.Brush.Text.Primary}"/>
        <Setter Property="Background"       Value="{DynamicResource Theme.Brush.Surface.Dark}"/>
        <Setter Property="BorderBrush"      Value="{DynamicResource Theme.Brush.Border.Default}"/>
        <Setter Property="BorderThickness"  Value="{DynamicResource Theme.BorderThickness.Heavy}"/>
        <Setter Property="FontSize"         Value="{DynamicResource Theme.Font.Size.Body}"/>
        <Setter Property="FontFamily"       Value="{DynamicResource Theme.Font.Family}"/>
        <Setter Property="Padding"          Value="8,0,0,0"/>
        <Setter Property="VerticalContentAlignment" Value="Center"/>
        <Setter Property="Cursor"           Value="Hand"/>
        <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
        <Setter Property="SnapsToDevicePixels" Value="True"/>

        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type CheckBox}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="20"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Border x:Name="CheckBorder"
                                Grid.Column="0"
                                Width="18" Height="18"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="{DynamicResource Theme.Radius.Medium}"
                                SnapsToDevicePixels="True">

                            <Path x:Name="CheckGlyph"
                                  Data="M 1,7 L 4,10 L 10,3"
                                  Stroke="{DynamicResource Theme.Brush.Border.Subtle}"
                                  StrokeThickness="1.8"
                                  StrokeStartLineCap="Round"
                                  StrokeEndLineCap="Round"
                                  StrokeLineJoin="Round"
                                  Stretch="None"
                                  HorizontalAlignment="Center"
                                  VerticalAlignment="Center"
                                  Visibility="Collapsed"/>
                        </Border>

                        <Border x:Name="IndeterminateMark"
                                Grid.Column="0"
                                Width="8" Height="2"
                                Background="{DynamicResource Theme.Brush.Border.Subtle}"
                                CornerRadius="{DynamicResource Theme.Radius.XSmall}"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                Visibility="Collapsed"/>

                        <ContentPresenter
                            Grid.Column="1"
                            Margin="{TemplateBinding Padding}"
                            VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                            RecognizesAccessKey="True"/>
                    </Grid>

                    <ControlTemplate.Triggers>
                        <Trigger Property="IsChecked" Value="True">
                            <Setter TargetName="CheckBorder" Property="Background"
                                    Value="{DynamicResource Theme.Brush.Accent.Base}"/>
                            <Setter TargetName="CheckBorder" Property="BorderBrush"
                                    Value="{DynamicResource Theme.Brush.Accent.Base}"/>
                            <Setter TargetName="CheckGlyph" Property="Visibility"
                                    Value="Visible"/>
                        </Trigger>

                        <Trigger Property="IsChecked" Value="{x:Null}">
                            <Setter TargetName="CheckBorder" Property="Background"
                                    Value="{DynamicResource Theme.Brush.Accent.Base}"/>
                            <Setter TargetName="CheckBorder" Property="BorderBrush"
                                    Value="{DynamicResource Theme.Brush.Accent.Base}"/>
                            <Setter TargetName="IndeterminateMark" Property="Visibility"
                                    Value="Visible"/>
                        </Trigger>

                        <MultiTrigger>
                            <MultiTrigger.Conditions>
                                <Condition Property="IsMouseOver" Value="True"/>
                                <Condition Property="IsChecked"   Value="False"/>
                            </MultiTrigger.Conditions>
                            <Setter TargetName="CheckBorder" Property="BorderBrush"
                                    Value="{DynamicResource Theme.Brush.Border.Hover}"/>
                            <Setter TargetName="CheckBorder" Property="Background"
                                    Value="{DynamicResource Theme.Brush.HoverOverlay}"/>
                        </MultiTrigger>

                        <MultiTrigger>
                            <MultiTrigger.Conditions>
                                <Condition Property="IsMouseOver" Value="True"/>
                                <Condition Property="IsChecked"   Value="True"/>
                            </MultiTrigger.Conditions>
                            <Setter TargetName="CheckBorder" Property="Background"
                                    Value="{DynamicResource Theme.Brush.Accent.Hover}"/>
                            <Setter TargetName="CheckBorder" Property="BorderBrush"
                                    Value="{DynamicResource Theme.Brush.Accent.Hover}"/>
                        </MultiTrigger>

                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="CheckBorder" Property="Background"
                                    Value="{DynamicResource Theme.Brush.Border.Subtle}"/>
                            <Setter TargetName="CheckBorder" Property="BorderBrush"
                                    Value="{DynamicResource Theme.Brush.Border.Subtle}"/>
                            <Setter Property="Foreground"
                                    Value="{DynamicResource Theme.Brush.Text.Muted}"/>
                        </Trigger>

                        <Trigger Property="IsFocused" Value="True">
                            <Setter TargetName="CheckBorder" Property="BorderBrush"
                                    Value="{DynamicResource Theme.Brush.Accent.Base}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

</ResourceDictionary>
