<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    
    <!-- ═══════════════════════════════════════════════════════════════
     EXPANDER STYLES — Themed (matches GroupBox)
     ═══════════════════════════════════════════════════════════════ -->

    <Style TargetType="{x:Type Expander}">
        <Setter Property="Foreground"       Value="{DynamicResource Theme.Brush.Text.Secondary}"/>
        <Setter Property="Background"       Value="{DynamicResource Theme.Brush.Surface.Mid}"/>
        <Setter Property="BorderBrush"      Value="{DynamicResource Theme.Brush.Border.Default}"/>
        <Setter Property="BorderThickness"  Value="{DynamicResource Theme.BorderThickness.Default}"/>
        <Setter Property="Padding"          Value="14,10"/>
        <Setter Property="FontSize"         Value="{DynamicResource Theme.Font.Size.Body}"/>
        <Setter Property="FontFamily"       Value="{DynamicResource Theme.Font.Family}"/>
        <Setter Property="SnapsToDevicePixels" Value="True"/>
        <Setter Property="Margin"           Value="0,4,0,4"/>

        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type Expander}">
                    <Grid SnapsToDevicePixels="True">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <!-- Background border spanning all rows -->
                        <Border Grid.Row="0" Grid.RowSpan="2"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="{DynamicResource Theme.Radius.XLarge}"/>

                        <!-- Header (clickable toggle) -->
                        <ToggleButton Grid.Row="0"
                                      IsChecked="{Binding IsExpanded, RelativeSource={RelativeSource TemplatedParent}}"
                                      OverridesDefaultStyle="True"
                                      Cursor="Hand"
                                      Focusable="False">
                            <ToggleButton.Template>
                                <ControlTemplate TargetType="{x:Type ToggleButton}">
                                    <Border x:Name="HeaderBorder"
                                            Background="Transparent"
                                            Padding="14,10,14,8"
                                            BorderBrush="{DynamicResource Theme.Brush.Border.Default}"
                                            BorderThickness="0">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>

                                            <!-- Header text -->
                                            <ContentPresenter Grid.Column="0"
                                                              Content="{Binding Header, RelativeSource={RelativeSource AncestorType=Expander}}"
                                                              RecognizesAccessKey="True"
                                                              TextBlock.Foreground="{DynamicResource Theme.Brush.Text.Primary}"
                                                              TextBlock.FontSize="{DynamicResource Theme.Font.Size.Body}"
                                                              TextBlock.FontWeight="SemiBold"
                                                              VerticalAlignment="Center"/>

                                            <!-- Chevron arrow -->
                                            <!-- Chevron arrow -->
                                            <Path x:Name="Arrow"
                                              Grid.Column="1"
                                              Data="M 0,0 L 5,5 L 10,0"
                                              Fill="{DynamicResource Theme.Brush.Text.Tertiary}"
                                              VerticalAlignment="Center"
                                              HorizontalAlignment="Right"
                                              Width="10" Height="6"
                                              Margin="8,0,4,0"/>
                                        </Grid>
                                    </Border>

                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="Arrow" Property="Fill" Value="{DynamicResource Theme.Brush.Text.Primary}"/>
                                        </Trigger>
                                        <Trigger Property="IsChecked" Value="True">
                                            <Setter TargetName="Arrow" Property="Data" Value="M 0,5 L 5,0 L 10,5"/>
                                            <Setter TargetName="HeaderBorder" Property="BorderThickness" Value="0,0,0,1"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </ToggleButton.Template>
                        </ToggleButton>

                        <!-- Collapsible content -->
                        <Border x:Name="ContentArea"
                                Grid.Row="1"
                                Visibility="Collapsed">
                            <ContentPresenter Margin="{TemplateBinding Padding}"/>
                        </Border>
                    </Grid>

                    <ControlTemplate.Triggers>
                        <Trigger Property="IsExpanded" Value="True">
                            <Setter TargetName="ContentArea" Property="Visibility" Value="Visible"/>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Foreground"
                                    Value="{DynamicResource Theme.Brush.Text.Muted}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>
</ResourceDictionary>
