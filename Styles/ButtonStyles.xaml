<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ═══════════════════════════════════════════════════════════════
         BUTTON STYLES — Themed
         Drop-in replacement for default WPF Button.
         
         Variants:
           (default)            Dark surface button
           AccentButtonStyle    Blue primary action button
         ═══════════════════════════════════════════════════════════════ -->

    <!-- ── Default Button ─────────────────────────────────────────── -->
    <Style TargetType="{x:Type Button}">
        <Setter Property="Foreground"       Value="{DynamicResource Theme.Brush.Text.Primary}"/>
        <Setter Property="Background"       Value="{DynamicResource Theme.Brush.Surface.Base}"/>
        <Setter Property="BorderBrush"      Value="{DynamicResource Theme.Brush.Border.Default}"/>
        <Setter Property="BorderThickness"  Value="{DynamicResource Theme.BorderThickness.Default}"/>
        <Setter Property="Padding"          Value="14,8"/>
        <Setter Property="FontSize"         Value="{DynamicResource Theme.Font.Size.Body}"/>
        <Setter Property="FontWeight"       Value="SemiBold"/>
        <Setter Property="FontFamily"       Value="{DynamicResource Theme.Font.Family}"/>
        <Setter Property="SnapsToDevicePixels" Value="True"/>
        <Setter Property="Cursor"           Value="Hand"/>
        <Setter Property="FocusVisualStyle" Value="{x:Null}"/>

        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type Button}">
                    <Border x:Name="Root"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="{DynamicResource Theme.Radius.Large}"
                            SnapsToDevicePixels="True">

                        <ContentPresenter
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Margin="{TemplateBinding Padding}"
                            RecognizesAccessKey="True"/>
                    </Border>

                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Root" Property="Background"
                                    Value="{DynamicResource Theme.Brush.Surface.Hover}"/>
                            <Setter TargetName="Root" Property="BorderBrush"
                                    Value="{DynamicResource Theme.Brush.FocusGlow50}"/>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="Root" Property="Background"
                                    Value="{DynamicResource Theme.Brush.Surface.Dark}"/>
                            <Setter TargetName="Root" Property="BorderBrush"
                                    Value="{DynamicResource Theme.Brush.FocusGlow30}"/>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="Root" Property="Background"
                                    Value="{DynamicResource Theme.Brush.Surface.Dark}"/>
                            <Setter TargetName="Root" Property="BorderBrush"
                                    Value="{DynamicResource Theme.Brush.Border.Subtle}"/>
                            <Setter Property="Foreground"
                                    Value="{DynamicResource Theme.Brush.Text.Muted}"/>
                        </Trigger>
                        <Trigger Property="IsFocused" Value="True">
                            <Setter TargetName="Root" Property="BorderBrush"
                                    Value="{DynamicResource Theme.Brush.Accent.Base}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ── Accent / Primary Button ────────────────────────────────── -->
    <Style x:Key="AccentButtonStyle" TargetType="{x:Type Button}">
        <Setter Property="Foreground"       Value="{DynamicResource Theme.Brush.White}"/>
        <Setter Property="Background"       Value="{DynamicResource Theme.Brush.Accent.Base}"/>
        <Setter Property="BorderBrush"      Value="{DynamicResource Theme.Brush.Accent.Base}"/>
        <Setter Property="BorderThickness"  Value="{DynamicResource Theme.BorderThickness.Default}"/>
        <Setter Property="Padding"          Value="14,8"/>
        <Setter Property="FontSize"         Value="{DynamicResource Theme.Font.Size.Body}"/>
        <Setter Property="FontWeight"       Value="SemiBold"/>
        <Setter Property="FontFamily"       Value="{DynamicResource Theme.Font.Family}"/>
        <Setter Property="SnapsToDevicePixels" Value="True"/>
        <Setter Property="Cursor"           Value="Hand"/>
        <Setter Property="FocusVisualStyle" Value="{x:Null}"/>

        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type Button}">
                    <Border x:Name="Root"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="{DynamicResource Theme.Radius.Large}"
                            SnapsToDevicePixels="True">

                        <ContentPresenter
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Margin="{TemplateBinding Padding}"
                            RecognizesAccessKey="True"/>
                    </Border>

                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Root" Property="Background"
                                    Value="{DynamicResource Theme.Brush.Accent.Hover}"/>
                            <Setter TargetName="Root" Property="BorderBrush"
                                    Value="{DynamicResource Theme.Brush.Accent.Hover}"/>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="Root" Property="Background"
                                    Value="{DynamicResource Theme.Brush.Accent.Pressed}"/>
                            <Setter TargetName="Root" Property="BorderBrush"
                                    Value="{DynamicResource Theme.Brush.Accent.Pressed}"/>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="Root" Property="Background"
                                    Value="{DynamicResource Theme.Brush.Surface.Dark}"/>
                            <Setter TargetName="Root" Property="BorderBrush"
                                    Value="{DynamicResource Theme.Brush.Border.Subtle}"/>
                            <Setter Property="Foreground"
                                    Value="{DynamicResource Theme.Brush.Text.Muted}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

</ResourceDictionary>
