<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ═══════════════════════════════════════════════════════════════
         GROUPBOX STYLES — Themed
         Drop-in replacement for default WPF GroupBox.
         ═══════════════════════════════════════════════════════════════ -->

    <Style TargetType="{x:Type GroupBox}">
        <Setter Property="Foreground"       Value="{DynamicResource Theme.Brush.Text.Secondary}"/>
        <Setter Property="Background"       Value="{DynamicResource Theme.Brush.Surface.Mid}"/>
        <Setter Property="BorderBrush"      Value="{DynamicResource Theme.Brush.Border.Default}"/>
        <Setter Property="BorderThickness"  Value="{DynamicResource Theme.BorderThickness.Default}"/>
        <Setter Property="Padding"          Value="14,10"/>
        <Setter Property="FontSize"         Value="{DynamicResource Theme.Font.Size.Body}"/>
        <Setter Property="FontFamily"       Value="{DynamicResource Theme.Font.Family}"/>
        <Setter Property="SnapsToDevicePixels" Value="True"/>
        <Setter Property="Margin" Value="0,4,0,4"/>

        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type GroupBox}">
                    <Grid SnapsToDevicePixels="True">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <Border Grid.Row="0" Grid.RowSpan="2"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="{DynamicResource Theme.Radius.XLarge}"/>

                        <Border Grid.Row="0"
                                Padding="14,10,14,8"
                                BorderBrush="{DynamicResource Theme.Brush.Border.Default}"
                                BorderThickness="0,0,0,1">
                            <ContentPresenter ContentSource="Header"
                                              RecognizesAccessKey="True"
                                              TextBlock.Foreground="{DynamicResource Theme.Brush.Text.Primary}"
                                              TextBlock.FontSize="{DynamicResource Theme.Font.Size.Body}"
                                              TextBlock.FontWeight="SemiBold"/>
                        </Border>

                        <ContentPresenter Grid.Row="1"
                                          Margin="{TemplateBinding Padding}"/>
                    </Grid>

                    <ControlTemplate.Triggers>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Foreground"
                                    Value="{DynamicResource Theme.Brush.Text.Muted}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ── Accent variant (blue left border) ──────────────────────── -->
    <Style x:Key="AccentGroupBoxStyle" TargetType="{x:Type GroupBox}">
        <Setter Property="Foreground"       Value="{DynamicResource Theme.Brush.Text.Secondary}"/>
        <Setter Property="Background"       Value="{DynamicResource Theme.Brush.Surface.Mid}"/>
        <Setter Property="BorderBrush"      Value="{DynamicResource Theme.Brush.Border.Default}"/>
        <Setter Property="BorderThickness"  Value="{DynamicResource Theme.BorderThickness.Default}"/>
        <Setter Property="Padding"          Value="14,10"/>
        <Setter Property="FontSize"         Value="{DynamicResource Theme.Font.Size.Body}"/>
        <Setter Property="FontFamily"       Value="{DynamicResource Theme.Font.Family}"/>
        <Setter Property="SnapsToDevicePixels" Value="True"/>

        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type GroupBox}">
                    <Grid SnapsToDevicePixels="True">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <Border Grid.Row="0" Grid.RowSpan="2"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="{DynamicResource Theme.Radius.XLarge}"/>

                        <Border Grid.Row="0" Grid.RowSpan="2"
                                HorizontalAlignment="Left"
                                Width="3" Margin="0,8"
                                Background="{DynamicResource Theme.Brush.Accent.Base}"
                                CornerRadius="2"/>

                        <Border Grid.Row="0"
                                Padding="20,10,14,8"
                                BorderBrush="{DynamicResource Theme.Brush.Border.Default}"
                                BorderThickness="0,0,0,1">
                            <ContentPresenter ContentSource="Header"
                                              RecognizesAccessKey="True"
                                              TextBlock.Foreground="{DynamicResource Theme.Brush.Text.Primary}"
                                              TextBlock.FontSize="{DynamicResource Theme.Font.Size.Body}"
                                              TextBlock.FontWeight="SemiBold"/>
                        </Border>

                        <ContentPresenter Grid.Row="1"
                                          Margin="20,10,14,10"/>
                    </Grid>

                    <ControlTemplate.Triggers>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Foreground"
                                    Value="{DynamicResource Theme.Brush.Text.Muted}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

</ResourceDictionary>
