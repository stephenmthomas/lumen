<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="clr-namespace:DisplayControl.Controls">

    <!-- ═══════════════════════════════════════════════════════════════
         RANGE SLIDER STYLES — Dark Theme Suite
         Template for DisplayControl.Controls.RangeSlider.
         
         Two-thumb range selector for min/max values.
         Blue filled region between thumbs, grey track outside.
         
         Usage:
           <controls:RangeSlider Minimum="0" Maximum="255"
                                  RangeMin="30" RangeMax="220" />
         ═══════════════════════════════════════════════════════════════ -->



    <!-- ── Range Thumb Style ──────────────────────────────────────── -->
    <Style x:Key="RangeSliderThumbStyle" TargetType="{x:Type Thumb}">
        <Setter Property="Width"  Value="18"/>
        <Setter Property="Height" Value="18"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="SnapsToDevicePixels" Value="True"/>
        <Setter Property="OverridesDefaultStyle" Value="True"/>

        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type Thumb}">
                    <Grid>
                        <!-- Hover halo -->
                        <Ellipse x:Name="Shadow"
                                 Width="18" Height="18"
                                 Fill="Transparent"
                                 StrokeThickness="0"/>

                        <!-- Main thumb circle -->
                        <Ellipse x:Name="ThumbCircle"
                                 Width="16" Height="16"
                                 Fill="{DynamicResource Theme.Brush.Accent.Base}"
                                 Stroke="{DynamicResource Theme.Brush.Border.Hover}"
                                 StrokeThickness="2"/>
                    </Grid>

                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="ThumbCircle" Property="Fill" Value="{DynamicResource Theme.Brush.Accent.Hover}"/>
                            <Setter TargetName="Shadow" Property="Fill" Value="{DynamicResource Theme.Brush.ThumbGlow}"/>
                            <Setter TargetName="Shadow" Property="Width"  Value="0"/>
                            <Setter TargetName="Shadow" Property="Height" Value="0"/>
                        </Trigger>
                        <Trigger Property="IsDragging" Value="True">
                            <Setter TargetName="ThumbCircle" Property="Fill" Value="{DynamicResource Theme.Brush.Accent.Pressed}"/>
                            <Setter TargetName="ThumbCircle" Property="Width"  Value="14"/>
                            <Setter TargetName="ThumbCircle" Property="Height" Value="14"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ── Disabled Range Thumb Style ─────────────────────────────── -->
    <Style x:Key="RangeSliderThumbDisabledStyle" TargetType="{x:Type Thumb}">
        <Setter Property="Width"  Value="18"/>
        <Setter Property="Height" Value="18"/>
        <Setter Property="SnapsToDevicePixels" Value="True"/>
        <Setter Property="OverridesDefaultStyle" Value="True"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type Thumb}">
                    <Ellipse Width="14" Height="14"
                             Fill="{StaticResource RangeSliderDisabledThumbBrush}"
                             Stroke="{StaticResource RangeSliderDisabledTrackBrush}"
                             StrokeThickness="2"/>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ═══════════════════════════════════════════════════════════════
         RANGE SLIDER CONTROL TEMPLATE
         
         Layout (all in a Canvas overlay on the track):
         
         ┌──────────────────────────────────────────────────────┐
         │  ░░░░░░░░▓▓▓▓▓▓▓▓▓▓▓▓▓▓▓▓▓▓▓▓▓▓▓░░░░░░░░░░░░░░░░ │
         │          ◉                        ◉                  │
         │       LowThumb              HighThumb                │
         │                                                      │
         │  ░ = Track (grey)    ▓ = RangeFill (blue)            │
         └──────────────────────────────────────────────────────┘
         ═══════════════════════════════════════════════════════════════ -->

    <Style TargetType="{x:Type controls:RangeSlider}">
        <Setter Property="MinHeight"           Value="20"/>
        <Setter Property="Height"              Value="20"/>
        <Setter Property="Background"          Value="Transparent"/>
        <Setter Property="FocusVisualStyle"    Value="{x:Null}"/>
        <Setter Property="SnapsToDevicePixels" Value="True"/>
        <Setter Property="IsTabStop"           Value="False"/>

        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type controls:RangeSlider}">
                    <Grid VerticalAlignment="Center"
                          SnapsToDevicePixels="True">

                        <!-- Background track (full width, grey) -->
                        <Border x:Name="PART_Track"
                                Height="4"
                                CornerRadius="2"
                                VerticalAlignment="Center"
                                SnapsToDevicePixels="True">
                            <Border.Background>
                                <Binding Path="TrackBrush"
                                         RelativeSource="{RelativeSource TemplatedParent}">
                                    <Binding.TargetNullValue>
                                        <SolidColorBrush Color="#3E3E44"/>
                                    </Binding.TargetNullValue>
                                </Binding>
                            </Border.Background>
                        </Border>

                        <!-- Canvas overlay for positioned elements -->
                        <Canvas Height="18"
                                VerticalAlignment="Center"
                                ClipToBounds="False">

                            <!-- Filled range bar (blue, between thumbs) -->
                            <Border x:Name="PART_RangeFill"
                                    Height="4"
                                    CornerRadius="2"
                                    Canvas.Top="7"
                                    Canvas.ZIndex="-1"
                                    SnapsToDevicePixels="True">
                                <Border.Background>
                                    <Binding Path="RangeFillBrush" RelativeSource="{RelativeSource TemplatedParent}">
                                        <Binding.TargetNullValue>
                                            <SolidColorBrush Color="{DynamicResource Theme.Accent.Base}"/>
                                        </Binding.TargetNullValue>
                                    </Binding>
                                </Border.Background>
                            </Border>

                            <!-- Low (min) thumb -->
                            <Thumb x:Name="PART_LowThumb"
                                   Style="{StaticResource RangeSliderThumbStyle}"
                                   Canvas.Top="0"
                                   Canvas.ZIndex="5"/>

                            <!-- High (max) thumb -->
                            <Thumb x:Name="PART_HighThumb"
                                   Style="{StaticResource RangeSliderThumbStyle}"
                                   Canvas.Top="0"/>
                        </Canvas>
                    </Grid>

                    <ControlTemplate.Triggers>
                        <!-- Disabled state -->
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="PART_Track" Property="Background"
                                    Value="{StaticResource RangeSliderDisabledTrackBrush}"/>
                            <Setter TargetName="PART_RangeFill" Property="Background"
                                    Value="{StaticResource RangeSliderDisabledFillBrush}"/>
                            <Setter TargetName="PART_LowThumb" Property="Style"
                                    Value="{StaticResource RangeSliderThumbDisabledStyle}"/>
                            <Setter TargetName="PART_HighThumb" Property="Style"
                                    Value="{StaticResource RangeSliderThumbDisabledStyle}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

</ResourceDictionary>
