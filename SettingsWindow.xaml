                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <GroupBox Header="Dynamic Enhancers">
                                            <StackPanel>
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="105"/>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="42"/>
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock Text="Dynamic Contrast" VerticalAlignment="Center" FontSize="10"/>
                                                    <Slider x:Name="DynamicContrastSlider" Grid.Column="1" Minimum="0" Maximum="100" Value="0" ValueChanged="DynamicContrastSlider_ValueChanged"/>
                                                    <TextBlock Grid.Column="2" Text="{Binding ElementName=DynamicContrastSlider, Path=Value, StringFormat='{}{0:F0}%'}" TextAlignment="Right" VerticalAlignment="Center" FontSize="10"/>
                                                </Grid>
                                                <TextBlock Text="Enhances midtone contrast with an S-curve. Adds pop without clipping." FontSize="9" Foreground="#707070" TextWrapping="Wrap" Margin="0,0,0,6"/>
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="105"/>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="42"/>
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock Text="Blue Light Filter" VerticalAlignment="Center" FontSize="10"/>
                                                    <Slider x:Name="BlueLightSlider" Grid.Column="1" Minimum="0" Maximum="100" Value="0" ValueChanged="BlueLightSlider_ValueChanged"/>
                                                    <TextBlock Grid.Column="2" Text="{Binding ElementName=BlueLightSlider, Path=Value, StringFormat='{}{0:F0}%'}" TextAlignment="Right" VerticalAlignment="Center" FontSize="10"/>
                                                </Grid>
                                                <TextBlock Text="Reduces blue light emission targeting the 450-480nm range that disrupts sleep." FontSize="9" Foreground="#707070" TextWrapping="Wrap" Margin="0,0,0,6"/>
                                            </StackPanel>
                                        </GroupBox>
                                        <GroupBox Header="Shadow / Highlight Recovery">
                                            <StackPanel>
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="105"/>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="42"/>
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock Text="Black Equalizer" VerticalAlignment="Center" FontSize="10"/>
                                                    <Slider x:Name="BlackEqualizerSlider" Grid.Column="1" Minimum="-100" Maximum="100" Value="0" ValueChanged="BlackEqualizerSlider_ValueChanged"/>
                                                    <TextBlock Grid.Column="2" Text="{Binding ElementName=BlackEqualizerSlider, Path=Value, StringFormat='{}{0:F0}'}" TextAlignment="Right" VerticalAlignment="Center" FontSize="10"/>
                                                </Grid>
                                                <TextBlock Text="Lifts shadow detail without affecting highlights. Positive values brighten dark areas." FontSize="9" Foreground="#707070" TextWrapping="Wrap" Margin="0,0,0,6"/>
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="105"/>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="42"/>
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock Text="White Equalizer" VerticalAlignment="Center" FontSize="10"/>
                                                    <Slider x:Name="WhiteEqualizerSlider" Grid.Column="1" Minimum="0" Maximum="100" Value="0" ValueChanged="WhiteEqualizerSlider_ValueChanged"/>
                                                    <TextBlock Grid.Column="2" Text="{Binding ElementName=WhiteEqualizerSlider, Path=Value, StringFormat='{}{0:F0}%'}" TextAlignment="Right" VerticalAlignment="Center" FontSize="10"/>
                                                </Grid>
                                                <TextBlock Text="Compresses highlights to recover blown-out detail in bright areas." FontSize="9" Foreground="#707070" TextWrapping="Wrap" Margin="0,0,0,6"/>
                                            </StackPanel>
                                        </GroupBox>
                                    </StackPanel>
                                </Grid>
                            </ScrollViewer>
                        </TabItem>

                        <TabItem Header="Filters">
                            <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                                <Grid Margin="9">
                                    
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <GroupBox Grid.Column="0" Header="Filter" Height="Auto">
