                                        <TextBlock Grid.Row="0" Grid.Column="3" Text="B" HorizontalAlignment="Center" FontSize="9" Foreground="#6666FF"/>
                                        <TextBlock Grid.Row="0" Grid.Column="4" Text="A" HorizontalAlignment="Center" FontSize="9" Foreground="#FFFFFF"/>
                                        <TextBlock Grid.Row="0" Grid.Column="5" Text="D" HorizontalAlignment="Center" FontSize="9" Foreground="#999999"/>
