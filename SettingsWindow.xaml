                                                        <ComboBoxItem Content="Inverted" Tag="Inverted"/>
                                                        <ComboBoxItem Content="Sepia" Tag="Sepia"/>
                                                        <ComboBoxItem Content="Night Light" Tag="NightLight"/>
                                                        <ComboBoxItem Content="High Contrast" Tag="HighContrast"/>
