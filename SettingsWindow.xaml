                                            <Expander Header="Basic">
                                                <StackPanel>
                                                    <Grid>
                                                        <!-- Brightness -->
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="65"/>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="42"/>
                                                        </Grid.ColumnDefinitions>
                                                        <TextBlock Text="Brightness" VerticalAlignment="Center" FontSize="10"/>
                                                        <Slider x:Name="FilterBrightnessSlider" Grid.Column="1" Minimum="-100" Maximum="100" Value="0" ValueChanged="FilterBrightnessSlider_ValueChanged"/>
                                                        <TextBlock Grid.Column="2" Text="{Binding ElementName=FilterBrightnessSlider, Path=Value, StringFormat='{}{0:F0}'}" TextAlignment="Right" VerticalAlignment="Center" FontSize="10"/>
                                                    </Grid>

                                                    <Grid>
                                                        <!-- Contrast -->
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="65"/>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="42"/>
                                                        </Grid.ColumnDefinitions>
                                                        <TextBlock Text="Contrast" VerticalAlignment="Center" FontSize="10"/>
                                                        <Slider x:Name="FilterContrastSlider" Grid.Column="1" Minimum="0" Maximum="200" Value="100" ValueChanged="FilterContrastSlider_ValueChanged"/>
                                                        <TextBlock Grid.Column="2" Text="{Binding ElementName=FilterContrastSlider, Path=Value, StringFormat='{}{0:F0}'}" TextAlignment="Right" VerticalAlignment="Center" FontSize="10"/>
                                                    </Grid>

                                                    <Grid>
                                                        <!-- Saturation -->
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="65"/>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="42"/>
                                                        </Grid.ColumnDefinitions>
                                                        <TextBlock Text="Saturation" VerticalAlignment="Center" FontSize="10"/>
                                                        <Slider x:Name="FilterSaturationSlider" Grid.Column="1" Minimum="0" Maximum="300" Value="100" ValueChanged="FilterSaturationSlider_ValueChanged"/>
                                                        <TextBlock Grid.Column="2" Text="{Binding ElementName=FilterSaturationSlider, Path=Value, StringFormat='{}{0:F0}'}" TextAlignment="Right" VerticalAlignment="Center" FontSize="10"/>
                                                    </Grid>

                                                    <Grid>
                                                        <!-- Hue -->
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="65"/>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="42"/>
                                                        </Grid.ColumnDefinitions>
                                                        <TextBlock Text="Hue Rotation" VerticalAlignment="Center" FontSize="10"/>
                                                        <Slider x:Name="FilterHueSlider" Grid.Column="1" Minimum="-180" Maximum="180" Value="0" ValueChanged="FilterHueSlider_ValueChanged"/>
                                                        <TextBlock Grid.Column="2" Text="{Binding ElementName=FilterHueSlider, Path=Value, StringFormat='{}{0:F0}°'}" TextAlignment="Right" VerticalAlignment="Center" FontSize="10"/>
                                                    </Grid>
                                                </StackPanel>
                                            </Expander>

                                            <Expander Header="Advanced">
                                                <StackPanel>
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="65"/>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="42"/>
                                                        </Grid.ColumnDefinitions>
                                                        <TextBlock Text="Vibrance" VerticalAlignment="Center" FontSize="10"/>
                                                        <Slider x:Name="FilterVibranceSlider" Grid.Column="1" Minimum="-100" Maximum="100" Value="0" ValueChanged="FilterVibranceSlider_ValueChanged"/>
                                                        <TextBlock Grid.Column="2" Text="{Binding ElementName=FilterVibranceSlider, Path=Value, StringFormat='{}{0:F0}'}" TextAlignment="Right" VerticalAlignment="Center" FontSize="10"/>
                                                    </Grid>

                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="65"/>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="42"/>
                                                        </Grid.ColumnDefinitions>
                                                        <TextBlock Text="Exposure" VerticalAlignment="Center" FontSize="10"/>
                                                        <Slider x:Name="FilterExposureSlider" Grid.Column="1" Minimum="-300" Maximum="300" Value="0" ValueChanged="FilterExposureSlider_ValueChanged"/>
                                                        <TextBlock Grid.Column="2" Text="{Binding ElementName=FilterExposureSlider, Path=Value, StringFormat='{}{0:F1}'}" TextAlignment="Right" VerticalAlignment="Center" FontSize="10"/>
                                                    </Grid>

                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="65"/>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="42"/>
                                                        </Grid.ColumnDefinitions>
                                                        <TextBlock Text="Temp (K)" VerticalAlignment="Center" FontSize="10"/>
                                                        <Slider x:Name="FilterTemperatureSlider" Style="{StaticResource TemperatureSliderStyle}" Grid.Column="1" Minimum="2000" Maximum="10000" Value="6500" ValueChanged="FilterTemperatureSlider_ValueChanged"/>
