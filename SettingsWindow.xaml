                                                    </Grid>

                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="65"/>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="42"/>
                                                        </Grid.ColumnDefinitions>
                                                        <TextBlock Text="Inversion" VerticalAlignment="Center" FontSize="10"/>
                                                        <Slider x:Name="FilterInversionSlider" Grid.Column="1" Minimum="0" Maximum="100" Value="0" ValueChanged="FilterInversionSlider_ValueChanged"/>
                                                        <TextBlock Grid.Column="2" Text="{Binding Value, ElementName=FilterInversionSlider, StringFormat={}{0:F0}%}" VerticalAlignment="Center" TextAlignment="Right" FontSize="10"/>
                                                    </Grid>

                                                </StackPanel>
                                            </Expander>

                                            <Expander Header="Levels">
                                                <StackPanel>
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="65"/>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="42"/>
                                                        </Grid.ColumnDefinitions>
                                                        <TextBlock Text="Black Point" VerticalAlignment="Center" FontSize="10"/>
                                                        <Slider x:Name="FilterBlackPointSlider" Grid.Column="1" Minimum="0" Maximum="30" Value="0" ValueChanged="FilterBlackPointSlider_ValueChanged"/>
                                                        <TextBlock Grid.Column="2" Text="{Binding ElementName=FilterBlackPointSlider, Path=Value, StringFormat='{}{0:F0}'}" TextAlignment="Right" VerticalAlignment="Center" FontSize="10"/>
                                                    </Grid>

                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="65"/>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="42"/>
                                                        </Grid.ColumnDefinitions>
                                                        <TextBlock Text="White Point" VerticalAlignment="Center" FontSize="10"/>
                                                        <Slider x:Name="FilterWhitePointSlider" Grid.Column="1" Minimum="70" Maximum="100" Value="100" ValueChanged="FilterWhitePointSlider_ValueChanged"/>
                                                        <TextBlock Grid.Column="2" Text="{Binding ElementName=FilterWhitePointSlider, Path=Value, StringFormat='{}{0:F0}'}" TextAlignment="Right" VerticalAlignment="Center" FontSize="10"/>
                                                    </Grid>
                                                </StackPanel>
                                            </Expander>

                                            <Expander Header="Channel Gain">
                                                <StackPanel>
                                                    <Grid>
                                                        <!-- Red Gain -->
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="65"/>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="42"/>
                                                        </Grid.ColumnDefinitions>
                                                        <TextBlock Text="Red" VerticalAlignment="Center" FontSize="10"/>
                                                        <Slider x:Name="FilterRedGainSlider" Style="{StaticResource RedSliderStyle}" Grid.Column="1" Minimum="0" Maximum="200" Value="100" ValueChanged="FilterChannelGain_ValueChanged"/>
                                                        <TextBlock Grid.Column="2" Text="{Binding ElementName=FilterRedGainSlider, Path=Value, StringFormat='{}{0:F0}'}" TextAlignment="Right" VerticalAlignment="Center" FontSize="10"/>
                                                    </Grid>

                                                    <Grid>
                                                        <!-- Green Gain -->
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="65"/>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="42"/>
                                                        </Grid.ColumnDefinitions>
                                                        <TextBlock Text="Green" VerticalAlignment="Center" FontSize="10"/>
                                                        <Slider x:Name="FilterGreenGainSlider" Style="{StaticResource GreenSliderStyle}" Grid.Column="1" Minimum="0" Maximum="200" Value="100" ValueChanged="FilterChannelGain_ValueChanged"/>
                                                        <TextBlock Grid.Column="2" Text="{Binding ElementName=FilterGreenGainSlider, Path=Value, StringFormat='{}{0:F0}'}" TextAlignment="Right" VerticalAlignment="Center" FontSize="10"/>
                                                    </Grid>

                                                    <Grid>
                                                        <!-- Blue Gain -->
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="65"/>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="42"/>
                                                        </Grid.ColumnDefinitions>
                                                        <TextBlock Text="Blue" VerticalAlignment="Center" FontSize="10"/>
                                                        <Slider x:Name="FilterBlueGainSlider" Style="{StaticResource BlueSliderStyle}" Grid.Column="1" Minimum="0" Maximum="200" Value="100" ValueChanged="FilterChannelGain_ValueChanged"/>
                                                        <TextBlock Grid.Column="2" Text="{Binding ElementName=FilterBlueGainSlider, Path=Value, StringFormat='{}{0:F0}'}" TextAlignment="Right" VerticalAlignment="Center" FontSize="10"/>
                                                    </Grid>
                                                </StackPanel>
                                            </Expander>

                                            <Expander Header="Channel Offset">
                                                <StackPanel>
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="65"/>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="42"/>
                                                        </Grid.ColumnDefinitions>
                                                        <TextBlock Text="Red" VerticalAlignment="Center" FontSize="10"/>
                                                        <Slider x:Name="FilterRedOffsetSlider" Style="{StaticResource RedSliderStyle}" Grid.Column="1" Minimum="-100" Maximum="100" Value="0" ValueChanged="FilterChannelOffset_ValueChanged"/>
                                                        <TextBlock Grid.Column="2" Text="{Binding ElementName=FilterRedOffsetSlider, Path=Value, StringFormat='{}{0:F0}'}" TextAlignment="Right" VerticalAlignment="Center" FontSize="10"/>
                                                    </Grid>

                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="65"/>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="42"/>
                                                        </Grid.ColumnDefinitions>
                                                        <TextBlock Text="Green" VerticalAlignment="Center" FontSize="10"/>
                                                        <Slider x:Name="FilterGreenOffsetSlider" Style="{StaticResource GreenSliderStyle}" Grid.Column="1" Minimum="-100" Maximum="100" Value="0" ValueChanged="FilterChannelOffset_ValueChanged"/>
                                                        <TextBlock Grid.Column="2" Text="{Binding ElementName=FilterGreenOffsetSlider, Path=Value, StringFormat='{}{0:F0}'}" TextAlignment="Right" VerticalAlignment="Center" FontSize="10"/>
                                                    </Grid>

                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="65"/>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="42"/>
                                                        </Grid.ColumnDefinitions>
                                                        <TextBlock Text="Blue" VerticalAlignment="Center" FontSize="10"/>
                                                        <Slider x:Name="FilterBlueOffsetSlider" Style="{StaticResource BlueSliderStyle}" Grid.Column="1" Minimum="-100" Maximum="100" Value="0" ValueChanged="FilterChannelOffset_ValueChanged"/>
                                                        <TextBlock Grid.Column="2" Text="{Binding ElementName=FilterBlueOffsetSlider, Path=Value, StringFormat='{}{0:F0}'}" TextAlignment="Right" VerticalAlignment="Center" FontSize="10"/>
                                                    </Grid>
                                                </StackPanel>
                                            </Expander>

                                            <Separator Margin="0,9,0,9" Background="{DynamicResource Theme.Brush.Border.Separator}"/>

                                            <TextBlock Text="Presets" FontWeight="SemiBold" Margin="0,0,0,6"/>
                                            <TextBlock Text="Presets can be mixed with the above settings." FontSize="9" Foreground="#9A9AA4" Margin="0,0,0,9"/>
                                            
                                            <Expander Header="Preset">
                                                <StackPanel>
                                                    <ComboBox x:Name="FilterPresetComboBox" SelectionChanged="FilterPresetComboBox_SelectionChanged" Margin="0,0,0,9">
