<Window x:Class="DisplayControl.SettingsWindow" 
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" 
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" 
        xmlns:controls="clr-namespace:DisplayControl.Controls" 
        Title="μLumen" 
        Height="700" 
        Width="900" 
        ResizeMode="CanResize" 
        Background="#1E1E22" 
        Foreground="#FFFFFF" 
        Icon="app.ico" 
        WindowStyle="None" 
        Left="-5000">
    <!-- Loads off screen to prevent flicker. -->

    <Window.Resources>
        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="#FFFFFF"/>
            <Setter Property="FontSize" Value="11"/>
        </Style>
        <Style x:Key="PresetButton" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Margin" Value="3"/>
            <Setter Property="MinWidth" Value="60"/>
        </Style>
        <Style x:Key="SmallButton" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Padding" Value="6,3"/>
            <Setter Property="FontSize" Value="9"/>
            <Setter Property="Margin" Value="3,0"/>
        </Style>
        <Style x:Key="CaptionBarButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#AAFFFFFF"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Width" Value="24"/>
            <Setter Property="Height" Value="24"/>
            <Setter Property="FontFamily" Value="Segoe MDL2 Assets"/>
            <Setter Property="FontSize" Value="10"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root" Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#30FFFFFF"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#50FFFFFF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="CaptionBarButtonCloseStyle" TargetType="Button" BasedOn="{StaticResource CaptionBarButtonStyle}">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root" Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#C42B1C"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#A02010"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="TabNavButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#9A9AA4"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Margin" Value="12,0"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Foreground" Value="{DynamicResource Theme.Brush.Accent.Hover}"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Foreground" Value="{DynamicResource Theme.Brush.Accent.Light}"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="TabNavButtonActive" TargetType="Button" BasedOn="{StaticResource TabNavButton}">
            <Setter Property="Foreground" Value="{DynamicResource Theme.Brush.Accent.Base}"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>
    </Window.Resources>

    <Grid x:Name="Body">
        <Grid.RowDefinitions>
            <RowDefinition Height="32"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="27"/>
        </Grid.RowDefinitions>

        <Border x:Name="TitleBar" Grid.Row="0" Background="#151518" MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
            <Grid Height="32">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                    <Image Grid.Column="0" Source="app.ico" Width="16" Height="16" VerticalAlignment="Center" Margin="12,0,0,0" RenderOptions.BitmapScalingMode="HighQuality"/>
                    <TextBlock Text="μLumen" VerticalAlignment="Center" Margin="6,0,9,0" FontWeight="SemiBold" FontSize="11" Foreground="#B0B0B0"/>
                    <Button Content="&#xE700;" Click="PopOut_Menu" Margin="3,0,3,0" Style="{StaticResource CaptionBarButtonStyle}" Visibility="Collapsed"/>
                </StackPanel>
                
                <StackPanel x:Name="TabSwitches" Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                    <Button Content="Luma" Tag="0" Click="TabSwitch" Style="{StaticResource TabNavButtonActive}"/>
                    <Button Content="Chroma" Tag="1" Click="TabSwitch" Style="{StaticResource TabNavButton}"/>
                    <Button Content="Enhance" Tag="2" Click="TabSwitch" Style="{StaticResource TabNavButton}"/>
                    <Button Content="Filters" Tag="3" Click="TabSwitch" Style="{StaticResource TabNavButton}"/>
                    <Button Content="ICC Profiles" Tag="4" Click="TabSwitch" Style="{StaticResource TabNavButton}" Visibility="Collapsed"/>
                    <Button Content="Settings" Tag="5" Click="TabSwitch" Style="{StaticResource TabNavButton}"/>
                </StackPanel>
                
                <StackPanel Grid.Column="2" Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="&#xEF2D;" Click="MinimizeButton_Click" Margin="3,0,3,0" Style="{StaticResource CaptionBarButtonStyle}"/>
                    <Button Content="&#xEF2E;" Click="MaximizeButton_Click" Margin="3,0,3,0" Style="{StaticResource CaptionBarButtonStyle}"/>
                    <Button Content="&#xEF2C;" Click="CloseButton_Click" Margin="3,0,6,0" Style="{StaticResource CaptionBarButtonCloseStyle}"/>
                </StackPanel>
                
            </Grid>
        </Border>

        <Grid x:Name="AppBody" Grid.Row="1" Margin="0">
            <Grid Margin="6">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition/>
                    <ColumnDefinition Width="3*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Grid x:Name="StageToolbar" Grid.Row="0" Margin="15,3,15,3" Grid.ColumnSpan="2">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    
                    <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="Preset:" VerticalAlignment="Center" Margin="0,0,3,0" FontSize="11" Foreground="#B0B0B0"/>
                        <ComboBox x:Name="PresetComboBox" SelectionChanged="PresetComboBox_SelectionChanged" Width="120" MinWidth="50" Height="24" Margin="0,0,9,0" Style="{StaticResource CompactComboBox}">
                            <ComboBoxItem Content="Default" Tag="default"/>
                            <ComboBoxItem Content="Night" Tag="night"/>
                            <ComboBoxItem Content="Reading" Tag="reading"/>
                            <ComboBoxItem Content="Gaming" Tag="gaming"/>
                        </ComboBox>
                        <Button Content="&#xE74E;" FontFamily="Segoe Fluent Icons" ToolTip="Save current settings as preset." Click="SavePreset_Click" Height="24" Width="24" Padding="0"/>
                    </StackPanel>
                    
                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="Monitor:" VerticalAlignment="Center" Margin="0,0,3,0" FontSize="11" Foreground="#B0B0B0"/>
                        <ComboBox x:Name="MonitorComboBox" SelectionChanged="MonitorComboBox_SelectionChanged" Width="140" Height="24" Style="{StaticResource CompactComboBox}"/>
                    </StackPanel>

                    <StackPanel Grid.Column="2" Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                        <Button Content="&#xE898;" FontFamily="Segoe Fluent Icons" ToolTip="Apply Settings." Click="Apply_Click" Height="24" Width="24" Padding="0" Margin="3,0,15,0"/>
                        <Button Content="&#xE895;" FontFamily="Segoe Fluent Icons" ToolTip="Reset Gamma." Click="Reset_Click" Height="24" Width="24" Padding="0" Margin="3,0,3,0"/>
                        <Button Content="&#xE71C;" FontFamily="Segoe Fluent Icons" ToolTip="Reset Filter." Click="ResetFilters_Click" Height="24" Width="24" Padding="0" Margin="3,0,3,0"/>
                    </StackPanel>

                </Grid>

                <Grid x:Name="MainStage" Grid.ColumnSpan="2" Margin="0,33,0,0" Grid.RowSpan="3">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*" x:Name="InfoColumn"/>
                    </Grid.ColumnDefinitions>

                    <TabControl x:Name="MainTabs" Grid.Column="0" Grid.ColumnSpan="2" Margin="0,3,0,3" Grid.RowSpan="3" Style="{StaticResource TabPageControlStyle}" SelectedIndex="0">

                        <TabItem Header="Basic">
                            <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                                <Grid Margin="9">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    <Grid Grid.Row="0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="9"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0">
                                            <GroupBox Header="Exposure">
                                                <StackPanel VerticalAlignment="Center">
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="65"/>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="42"/>
                                                        </Grid.ColumnDefinitions>
                                                        <TextBlock Text="Exposure" VerticalAlignment="Center" FontSize="10"/>
                                                        <Slider x:Name="ExposureSlider" Grid.Column="1" Minimum="-300" Maximum="300" Value="0" ValueChanged="ExposureSlider_ValueChanged"/>
                                                        <TextBlock Grid.Column="2" Text="{Binding ElementName=ExposureSlider, Path=Value, StringFormat='{}{0:F0}'}" TextAlignment="Right" VerticalAlignment="Center" FontSize="10"/>
                                                    </Grid>
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="65"/>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="42"/>
                                                        </Grid.ColumnDefinitions>
                                                        <TextBlock Text="Offset" VerticalAlignment="Center" FontSize="10"/>
                                                        <Slider x:Name="OffsetSlider" Grid.Column="1" Minimum="-100" Maximum="100" Value="0" ValueChanged="OffsetSlider_ValueChanged"/>
                                                        <TextBlock Grid.Column="2" Text="{Binding ElementName=OffsetSlider, Path=Value, StringFormat='{}{0:F0}'}" TextAlignment="Right" VerticalAlignment="Center" FontSize="10"/>
                                                    </Grid>
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="65"/>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="42"/>
                                                        </Grid.ColumnDefinitions>
                                                        <TextBlock Text="Gamma" VerticalAlignment="Center" FontSize="10"/>
                                                        <Slider x:Name="GammaSlider" Grid.Column="1" Minimum="10" Maximum="300" Value="100" ValueChanged="GammaSlider_ValueChanged"/>
                                                        <TextBlock Grid.Column="2" Text="{Binding ElementName=GammaSlider, Path=Value, StringFormat='{}{0:F0}%'}" TextAlignment="Right" VerticalAlignment="Center" FontSize="10"/>
                                                    </Grid>
                                                </StackPanel>
                                            </GroupBox>
                                            <GroupBox Header="Shadows / Highlights">
                                                <StackPanel VerticalAlignment="Center">
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="65"/>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="42"/>
                                                        </Grid.ColumnDefinitions>
                                                        <TextBlock Text="Blacks" VerticalAlignment="Center" FontSize="10"/>
                                                        <Slider x:Name="BlacksSlider" Grid.Column="1" Minimum="-100" Maximum="100" Value="0" ValueChanged="BlacksSlider_ValueChanged"/>
                                                        <TextBlock Grid.Column="2" Text="{Binding ElementName=BlacksSlider, Path=Value, StringFormat='{}{0:F0}'}" TextAlignment="Right" VerticalAlignment="Center" FontSize="10"/>
                                                    </Grid>
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="65"/>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="42"/>
                                                        </Grid.ColumnDefinitions>
                                                        <TextBlock Text="Shadows" VerticalAlignment="Center" FontSize="10"/>
                                                        <Slider x:Name="ShadowsSlider" Grid.Column="1" Minimum="-100" Maximum="100" Value="0" ValueChanged="ShadowsSlider_ValueChanged"/>
                                                        <TextBlock Grid.Column="2" Text="{Binding ElementName=ShadowsSlider, Path=Value, StringFormat='{}{0:F0}'}" TextAlignment="Right" VerticalAlignment="Center" FontSize="10"/>
                                                    </Grid>
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="65"/>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="42"/>
                                                        </Grid.ColumnDefinitions>
                                                        <TextBlock Text="Midtones" VerticalAlignment="Center" FontSize="10"/>
                                                        <Slider x:Name="MidtonesSlider" Grid.Column="1" Minimum="-100" Maximum="100" Value="0" ValueChanged="MidtonesSlider_ValueChanged"/>
                                                        <TextBlock Grid.Column="2" Text="{Binding ElementName=MidtonesSlider, Path=Value, StringFormat='{}{0:F0}'}" TextAlignment="Right" VerticalAlignment="Center" FontSize="10"/>
                                                    </Grid>
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="65"/>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="42"/>
                                                        </Grid.ColumnDefinitions>
                                                        <TextBlock Text="Highlights" VerticalAlignment="Center" FontSize="10"/>
                                                        <Slider x:Name="HighlightsSlider" Grid.Column="1" Minimum="-100" Maximum="100" Value="0" ValueChanged="HighlightsSlider_ValueChanged"/>
                                                        <TextBlock Grid.Column="2" Text="{Binding ElementName=HighlightsSlider, Path=Value, StringFormat='{}{0:F0}'}" TextAlignment="Right" VerticalAlignment="Center" FontSize="10"/>
                                                    </Grid>
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="65"/>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="42"/>
                                                        </Grid.ColumnDefinitions>
                                                        <TextBlock Text="Whites" VerticalAlignment="Center" FontSize="10"/>
                                                        <Slider x:Name="WhitesSlider" Grid.Column="1" Minimum="-100" Maximum="100" Value="0" ValueChanged="WhitesSlider_ValueChanged"/>
                                                        <TextBlock Grid.Column="2" Text="{Binding ElementName=WhitesSlider, Path=Value, StringFormat='{}{0:F0}'}" TextAlignment="Right" VerticalAlignment="Center" FontSize="10"/>
                                                    </Grid>
                                                </StackPanel>
                                            </GroupBox>
                                        </StackPanel>
                                        <StackPanel Grid.Column="2">
                                            <GroupBox Header="Tone">
                                                <StackPanel VerticalAlignment="Center">
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="65"/>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="42"/>
                                                        </Grid.ColumnDefinitions>
                                                        <TextBlock Text="Brightness" VerticalAlignment="Center" FontSize="10"/>
                                                        <Slider x:Name="BrightnessSlider" Grid.Column="1" Minimum="0" Maximum="200" Value="100" ValueChanged="BrightnessSlider_ValueChanged"/>
                                                        <TextBlock Grid.Column="2" Text="{Binding ElementName=BrightnessSlider, Path=Value, StringFormat='{}{0:F0}%'}" TextAlignment="Right" VerticalAlignment="Center" FontSize="10"/>
                                                    </Grid>
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="65"/>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="42"/>
                                                        </Grid.ColumnDefinitions>
                                                        <TextBlock Text="Contrast" VerticalAlignment="Center" FontSize="10"/>
                                                        <Slider x:Name="ContrastSlider" Grid.Column="1" Minimum="0" Maximum="200" Value="100" ValueChanged="ContrastSlider_ValueChanged"/>
                                                        <TextBlock Grid.Column="2" Text="{Binding ElementName=ContrastSlider, Path=Value, StringFormat='{}{0:F0}%'}" TextAlignment="Right" VerticalAlignment="Center" FontSize="10"/>
                                                    </Grid>
                                                </StackPanel>
                                            </GroupBox>
                                            <GroupBox>
                                                <GroupBox.Header>
                                                    <CheckBox x:Name="LevelsEnabledCheckbox" Content="Levels" Checked="LevelsEnabled_Changed" Unchecked="LevelsEnabled_Changed" IsChecked="False"/>
                                                </GroupBox.Header>
                                                <StackPanel x:Name="LevelsPanel" IsEnabled="False" Opacity="0.75">
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="65"/>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="42"/>
                                                        </Grid.ColumnDefinitions>
                                                        <TextBlock Text="Input Black" VerticalAlignment="Center" FontSize="10"/>
                                                        <Slider x:Name="InputBlackSlider" Grid.Column="1" Minimum="0" Maximum="255" Value="0" ValueChanged="Levels_ValueChanged"/>
                                                        <TextBlock Grid.Column="2" Text="{Binding ElementName=InputBlackSlider, Path=Value, StringFormat='{}{0:F0}'}" TextAlignment="Right" VerticalAlignment="Center" FontSize="10"/>
                                                    </Grid>
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="65"/>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="42"/>
                                                        </Grid.ColumnDefinitions>
                                                        <TextBlock Text="Input White" VerticalAlignment="Center" FontSize="10"/>
                                                        <Slider x:Name="InputWhiteSlider" Grid.Column="1" Minimum="0" Maximum="255" Value="255" ValueChanged="Levels_ValueChanged"/>
                                                        <TextBlock Grid.Column="2" Text="{Binding ElementName=InputWhiteSlider, Path=Value, StringFormat='{}{0:F0}'}" TextAlignment="Right" VerticalAlignment="Center" FontSize="10"/>
                                                    </Grid>
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="65"/>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="42"/>
                                                        </Grid.ColumnDefinitions>
                                                        <TextBlock Text="Output Black" VerticalAlignment="Center" FontSize="10"/>
                                                        <Slider x:Name="OutputBlackSlider" Grid.Column="1" Minimum="0" Maximum="255" Value="0" ValueChanged="Levels_ValueChanged"/>
                                                        <TextBlock Grid.Column="2" Text="{Binding ElementName=OutputBlackSlider, Path=Value, StringFormat='{}{0:F0}'}" TextAlignment="Right" VerticalAlignment="Center" FontSize="10"/>
                                                    </Grid>
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="65"/>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="42"/>
                                                        </Grid.ColumnDefinitions>
                                                        <TextBlock Text="Output White" VerticalAlignment="Center" FontSize="10"/>
                                                        <Slider x:Name="OutputWhiteSlider" Grid.Column="1" Minimum="0" Maximum="255" Value="255" ValueChanged="Levels_ValueChanged"/>
                                                        <TextBlock Grid.Column="2" Text="{Binding ElementName=OutputWhiteSlider, Path=Value, StringFormat='{}{0:F0}'}" TextAlignment="Right" VerticalAlignment="Center" FontSize="10"/>
                                                    </Grid>
                                                    <controls:RangeSlider Minimum="0" Maximum="255" RangeMin="{Binding ShadowLevel}" RangeMax="{Binding HighlightLevel}" Step="1" Visibility="Collapsed"/>
                                                </StackPanel>
                                            </GroupBox>
                                        </StackPanel>
                                    </Grid>
                                    <Expander Grid.Row="1" Header="Master Curve (Luminance)" IsExpanded="False" Margin="0,9,0,0">
                                        <DockPanel>
                                            <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,0,0,42">
                                                <CheckBox x:Name="MasterCurveEnabled" Content="Enable" Checked="MasterCurveEnabled_Changed" Unchecked="MasterCurveEnabled_Changed" IsChecked="False" Margin="0,0,12,0"/>
                                                <Button Content="Reset" Style="{StaticResource SmallButton}" Click="ResetMasterCurve_Click"/>
                                            </StackPanel>
                                            <controls:CurveEditorControl x:Name="MasterCurveEditor" CurveColor="White" CurveChanged="MasterCurve_Changed" Height="280" Margin="3,0,3,0"/>
                                        </DockPanel>
                                    </Expander>
                                </Grid>
                            </ScrollViewer>
                        </TabItem>

                        <TabItem Header="Color">
                            <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                                <Grid Margin="9">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    <Grid Grid.Row="0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="9"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0">
                                            <GroupBox Header="White Balance">
                                                <StackPanel>
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="65"/>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="42"/>
                                                        </Grid.ColumnDefinitions>
                                                        <TextBlock Text="Temp" VerticalAlignment="Center" FontSize="10"/>
                                                        <Slider x:Name="ColorTempSlider" Style="{StaticResource TemperatureSliderStyle}" Grid.Column="1" Minimum="2000" Maximum="10000" Value="6500" ValueChanged="ColorTempSlider_ValueChanged"/>
                                                        <TextBlock Grid.Column="2" Text="{Binding ElementName=ColorTempSlider, Path=Value, StringFormat='{}{0:F0}K'}" TextAlignment="Right" VerticalAlignment="Center" FontSize="10"/>
                                                    </Grid>
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="65"/>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="42"/>
                                                        </Grid.ColumnDefinitions>
                                                        <TextBlock Text="Tint" VerticalAlignment="Center" FontSize="10"/>
                                                        <Slider x:Name="TintSlider" Style="{StaticResource TintSliderStyle}" Grid.Column="1" Minimum="-100" Maximum="100" Value="0" ValueChanged="TintSlider_ValueChanged"/>
                                                        <TextBlock Grid.Column="2" Text="{Binding ElementName=TintSlider, Path=Value, StringFormat='{}{0:F0}'}" TextAlignment="Right" VerticalAlignment="Center" FontSize="10"/>
                                                    </Grid>
                                                </StackPanel>
                                            </GroupBox>
                                            <GroupBox Header="Saturation">
                                                <StackPanel>
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="65"/>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="42"/>
                                                        </Grid.ColumnDefinitions>
                                                        <TextBlock Text="Vibrance" VerticalAlignment="Center" FontSize="10"/>
                                                        <Slider x:Name="VibranceSlider" Grid.Column="1" Minimum="-100" Maximum="100" Value="0" ValueChanged="VibranceSlider_ValueChanged"/>
                                                        <TextBlock Grid.Column="2" Text="{Binding ElementName=VibranceSlider, Path=Value, StringFormat='{}{0:F0}'}" TextAlignment="Right" VerticalAlignment="Center" FontSize="10"/>
                                                    </Grid>
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="65"/>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="42"/>
                                                        </Grid.ColumnDefinitions>
                                                        <TextBlock Text="Saturation" VerticalAlignment="Center" FontSize="10"/>
                                                        <Slider x:Name="SaturationSlider" Grid.Column="1" Minimum="0" Maximum="300" Value="100" ValueChanged="SaturationSlider_ValueChanged"/>
                                                        <TextBlock Grid.Column="2" Text="{Binding ElementName=SaturationSlider, Path=Value, StringFormat='{}{0:F0}%'}" TextAlignment="Right" VerticalAlignment="Center" FontSize="10"/>
                                                    </Grid>
                                                </StackPanel>
                                            </GroupBox>
                                        </StackPanel>
                                        <StackPanel Grid.Column="2">
                                            <GroupBox Header="RGB Channels">
                                                <StackPanel>
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="65"/>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="42"/>
                                                        </Grid.ColumnDefinitions>
                                                        <TextBlock Text="Red" Foreground="#FF6B6B" VerticalAlignment="Center" FontSize="10"/>
                                                        <Slider x:Name="RedGainSlider" Style="{StaticResource RedSliderStyle}" Grid.Column="1" Minimum="0" Maximum="200" Value="100" ValueChanged="RedGainSlider_ValueChanged"/>
                                                        <TextBlock Grid.Column="2" Text="{Binding ElementName=RedGainSlider, Path=Value, StringFormat='{}{0:F0}%'}" TextAlignment="Right" VerticalAlignment="Center" FontSize="10"/>
                                                    </Grid>
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="65"/>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="42"/>
                                                        </Grid.ColumnDefinitions>
                                                        <TextBlock Text="Green" Foreground="#51CF66" VerticalAlignment="Center" FontSize="10"/>
                                                        <Slider x:Name="GreenGainSlider" Style="{StaticResource GreenSliderStyle}" Grid.Column="1" Minimum="0" Maximum="200" Value="100" ValueChanged="GreenGainSlider_ValueChanged"/>
                                                        <TextBlock Grid.Column="2" Text="{Binding ElementName=GreenGainSlider, Path=Value, StringFormat='{}{0:F0}%'}" TextAlignment="Right" VerticalAlignment="Center" FontSize="10"/>
                                                    </Grid>
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="65"/>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="42"/>
                                                        </Grid.ColumnDefinitions>
                                                        <TextBlock Text="Blue" Foreground="#339AF0" VerticalAlignment="Center" FontSize="10"/>
