                                                </StackPanel>

                                                <TextBlock x:Name="ICCStatusText" Text="Select a Monitor..." FontSize="9" Foreground="#9A9AA4" Margin="0,6,0,18" TextWrapping="Wrap"/>

                                                <Separator Margin="3" Background="{DynamicResource Theme.Brush.Border.Default}"/>
                                                
                                                <TextBlock Text="System Access:" FontWeight="SemiBold" Margin="0,12,0,0"/>
                                                <Separator Margin="0,0,0,3" Background="{DynamicResource Theme.Brush.Border.Separator}"/>
                                                
                                                <StackPanel Orientation="Horizontal" Margin="0,0,0,9" HorizontalAlignment="Center">
                                                    <Button Content="Open Profile Folder" Click="OpenProfileFolder_Click" HorizontalAlignment="Left" Padding="9,3" FontSize="10" Margin="3,6,3,6"/>
                                                    <Button Content="Display Settings" Click="OpenDisplaySettings_Click" HorizontalAlignment="Left" Padding="9,3" FontSize="10" Margin="3,6,3,6"/>
                                                    <Button Content="Color Management" Click="OpenColorManagement_Click" HorizontalAlignment="Left" Padding="9,3" FontSize="10" Margin="3,6,3,6"/>
                                                </StackPanel>

                                                <TextBlock Text="Information:" FontWeight="SemiBold" Margin="0,12,0,0"/>
                                                <Separator Margin="0,6,0,3" Background="{DynamicResource Theme.Brush.Border.Separator}"/>
                                                
                                                <StackPanel Orientation="Horizontal" Margin="0,0,0,9" HorizontalAlignment="Center">
                                                    <Button Content="ICC Wikipedia" HorizontalAlignment="Left" Padding="9,3" FontSize="10" Margin="3,6,3,6" Click="ICCProfileWiki_Click"/>
                                                    <Button Content="ICC Official Profiles" HorizontalAlignment="Left" Padding="9,3" FontSize="10" Margin="3,6,3,6" Click="ICCProfilesURL_Click"/>
                                                </StackPanel>
                                                
                                            </StackPanel>
                                        </Expander>
                                        <Expander Header="Keyboard Shortcuts">
                                            <StackPanel>
                                                <Grid Margin="0,3">
                                                    <TextBlock Text="Brightness" FontSize="9" Foreground="#B0B0B0" HorizontalAlignment="Left"/>
                                                    <TextBlock Text="Ctrl+Alt+↑↓" FontSize="9" Foreground="#707070" HorizontalAlignment="Right"/>
                                                </Grid>
                                                <Grid Margin="0,3">
                                                    <TextBlock Text="Contrast" FontSize="9" Foreground="#B0B0B0" HorizontalAlignment="Left"/>
                                                    <TextBlock Text="Ctrl+Alt+←→" FontSize="9" Foreground="#707070" HorizontalAlignment="Right"/>
                                                </Grid>
                                                <Grid Margin="0,3">
                                                    <TextBlock Text="Gamma" FontSize="9" Foreground="#B0B0B0" HorizontalAlignment="Left"/>
                                                    <TextBlock Text="Ctrl+Shift+↑↓" FontSize="9" Foreground="#707070" HorizontalAlignment="Right"/>
                                                </Grid>
                                                <Grid Margin="0,3">
                                                    <TextBlock Text="Color Temp" FontSize="9" Foreground="#B0B0B0" HorizontalAlignment="Left"/>
                                                    <TextBlock Text="Ctrl+Shift+←→" FontSize="9" Foreground="#707070" HorizontalAlignment="Right"/>
                                                </Grid>
                                                <Grid Margin="0,3">
                                                    <TextBlock Text="Reset All" FontSize="9" Foreground="#B0B0B0" HorizontalAlignment="Left"/>
                                                    <TextBlock Text="Ctrl+Alt+R" FontSize="9" Foreground="#707070" HorizontalAlignment="Right"/>
                                                </Grid>
                                            </StackPanel>
                                        </Expander>
                                        <Expander Header="About">
                                            <StackPanel>
                                                <TextBlock Text="Display Control" FontSize="14" FontWeight="SemiBold" Foreground="#E4E4E8" Margin="0,6"/>
                                                <TextBlock x:Name="VersionTextBlock" Text="Version: O" FontSize="10" Foreground="#9A9AA4" Margin="0,3,0,9"/>
                                                <TextBlock Text="Advanced display color calibration and adjustment tool for Windows." FontSize="10" Foreground="#C8C8D0" TextWrapping="Wrap" Margin="0,0,0,12"/>
                                                <TextBlock Text="Features:" FontSize="10" FontWeight="SemiBold" Foreground="#E4E4E8" Margin="0,0,0,6"/>
                                                <TextBlock Text="• Parallel LUT and 5x5 Matrix pipelines" FontSize="9" Foreground="#9A9AA4" Margin="6,3"/>
                                                <TextBlock Text="• Advanced Curve Editors for gamma ramp manipulation" FontSize="9" Foreground="#9A9AA4" Margin="6,3"/>
                                                <TextBlock Text="• Per-channel RGB editing and adjustment" FontSize="9" Foreground="#9A9AA4" Margin="6,3"/>
                                                <TextBlock Text="• Global keyboard shortcuts for quick display editing" FontSize="9" Foreground="#9A9AA4" Margin="6,3"/>
                                                <Button Content="Check for Updates" HorizontalAlignment="Left" Margin="0,6" Click="VisitGit_Click"/>
                                            </StackPanel>
                                        </Expander>
                                        <Expander Header="Support">
                                            <StackPanel>
                                                <Button Content="View Documentation" HorizontalAlignment="Stretch" Margin="0,3" Click="ViewDocs_Click"/>
                                                <Button Content="Report an Issue" HorizontalAlignment="Stretch" Margin="0,3" Click="ReportIssue_Click"/>
                                                <Button Content="Visit GitHub" HorizontalAlignment="Stretch" Margin="0,3" Click="VisitGit_Click"/>
                                            </StackPanel>
                                        </Expander>
                                    </StackPanel>

                                </Grid>
                            </ScrollViewer>
                        </TabItem>

                    </TabControl>

                    <Border x:Name="InfoPanel" Grid.Column="2" BorderBrush="{DynamicResource Theme.Brush.Border.Subtle}" BorderThickness="1,0,0,0" Padding="9">
                        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                            <StackPanel>
                                
                                <Expander Header="Gamma Ramp" IsExpanded="True" Margin="0,3,0,3">
                                    <controls:GammaRampDisplay x:Name="GammaRampView" Height="200"/>
                                </Expander>
                                
                                <Expander Header="Histogram" Margin="0,3,0,3">
                                    <StackPanel>
                                        <StackPanel HorizontalAlignment="Center" Orientation="Horizontal" Margin="0">
                                            <!-- CheckBox Content="RGB" IsChecked="{Binding ShowRGB, ElementName=HistogramDisplay}" Foreground="#B4B4B4" Margin="0,0,3,0"/ -->
                                            <CheckBox Content="R" IsChecked="{Binding ShowRed, ElementName=HistogramDisplay}" Foreground="#DC3C3C" Margin="0,0,3,0"/>
                                            <CheckBox Content="G" IsChecked="{Binding ShowGreen, ElementName=HistogramDisplay}" Foreground="#3CC850" Margin="0,0,3,0"/>
                                            <CheckBox Content="B" IsChecked="{Binding ShowBlue, ElementName=HistogramDisplay}" Foreground="#3C78DC" Margin="0,0,3,0"/>
                                            <CheckBox Content="LUM" IsChecked="{Binding ShowLuminance, ElementName=HistogramDisplay}" Foreground="#C8C8C8" Margin="0,0,3,0"/>
                                        </StackPanel>


                                        <controls:HistogramControl x:Name="HistogramDisplay" Height="180" Margin="6" ShowRed="True" ShowGreen="True" ShowBlue="True" ShowLuminance="False" UseLogScale="False"/>
