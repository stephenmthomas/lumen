                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">

                                    </StackPanel>
                                </Grid>
                            </ScrollViewer>
                        </TabItem>

                        <TabItem Header="Settings">
                            <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                                <Grid Margin="9">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <StackPanel Grid.Column="0">
                                        <Expander Header="Settings">
                                            <StackPanel>

                                                <TextBlock Text="Application Behavior" FontSize="14" Foreground="{DynamicResource Theme.Brush.Text.Primary}" Margin="0,6,0,3"/>
                                                <Separator Margin="0,0,0,9" Background="{DynamicResource Theme.Brush.Border.Separator}"/>

                                                <CheckBox x:Name="StartMinimizedCheckbox" Content="Start to System Tray" IsChecked="True" Margin="18,6" Click="StartMinimizedCheckbox_Click"/>
