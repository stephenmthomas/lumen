                                                <CheckBox x:Name="ApplyRealTimeCheckbox" Content="Real-Time Changes" IsChecked="True" Margin="18,6" Click="ApplyRealTimeCheckbox_Click"/>
                                                <TextBlock Text="Apply adjustments instantly as sliders move. Disable for better performance on slower systems." FontSize="9" Foreground="#707070" TextWrapping="Wrap" Margin="21,0,0,9"/>
                                                <CheckBox x:Name="RealTimeHistogramCheckbox" Content="Real-Time Histogram" IsChecked="True" Margin="18,6" Click="RealTimeHistogramCheckbox_Click"/>
                                                <TextBlock Text="Update the histogram on slider movement. Disable for better performance on slower systems." FontSize="9" Foreground="#707070" TextWrapping="Wrap" Margin="21,0,0,9"/>
                                                <CheckBox x:Name="AlwaysOnTopCheckbox" Content="Always On Top" IsChecked="True" Margin="18,6" Click="AlwaysOnTopCheckbox_Click"/>
                                                <TextBlock Text="Keep the form always on top of other application windows." FontSize="9" Foreground="#707070" TextWrapping="Wrap" Margin="21,0,0,9"/>


                                                <TextBlock Text="Backend Gamma" FontSize="16" Foreground="{DynamicResource Theme.Brush.Text.Primary}" Margin="0,18,0,3"/>
                                                <Separator Margin="0,0,0,9" Background="{DynamicResource Theme.Brush.Border.Separator}"/>

                                                <StackPanel Orientation="Horizontal" Margin="0,6,0,6" HorizontalAlignment="Center">
                                                    <RadioButton x:Name="BackendGDI" Content="GDI" GroupName="DisplayBackend" IsChecked="True" Margin="0,0,12,0" Checked="DisplayBackend_Changed"/>
                                                    <RadioButton x:Name="BackendDXGI" Content="DXGI" GroupName="DisplayBackend" Checked="DisplayBackend_Changed"/>
