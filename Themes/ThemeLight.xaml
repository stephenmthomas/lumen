<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:sys="clr-namespace:System;assembly=mscorlib">

    <!-- ═══════════════════════════════════════════════════════════════
         light THEME
         ═══════════════════════════════════════════════════════════════ -->

    <!-- ── SURFACE HIERARCHY (backgrounds, dark → light) ─────────── -->
    <Color x:Key="Theme.Surface.Darkest">#E8E8EC</Color>
    <Color x:Key="Theme.Surface.Dark">#F0F0F4</Color>
    <Color x:Key="Theme.Surface.Mid">#F5F5F8</Color>
    <Color x:Key="Theme.Surface.Base">#FFFFFF</Color>
    <Color x:Key="Theme.Surface.Raised">#E4E4EA</Color>
    <Color x:Key="Theme.Surface.Hover">#EDEDF2</Color>
    <Color x:Key="Theme.Surface.Popup">#FFFFFF</Color>

    <!-- ── BORDERS ───────────────────────────────────────────────── -->
    <Color x:Key="Theme.Border.Subtle">#DCDCE2</Color>
    <Color x:Key="Theme.Border.Default">#C8C8D0</Color>
    <Color x:Key="Theme.Border.Hover">#A0A0AA</Color>
    <Color x:Key="Theme.Border.Separator">#E0E0E6</Color>

    <!-- ── TEXT ───────────────────────────────────────────────────── -->
    <Color x:Key="Theme.Text.Primary">#1E1E22</Color>
    <Color x:Key="Theme.Text.Secondary">#3A3A42</Color>
    <Color x:Key="Theme.Text.Tertiary">#6A6A74</Color>
    <Color x:Key="Theme.Text.Muted">#A0A0AA</Color>
    <Color x:Key="Theme.Text.Placeholder">#9A9AA4</Color>
    <Color x:Key="Theme.Text.PlaceholderAlt">#8A8A94</Color>

    <!-- ── ACCENT (primary blue) ─────────────────────────────────── -->
    <Color x:Key="Theme.Accent.Base">#2563EB</Color>
    <Color x:Key="Theme.Accent.Hover">#3B82F6</Color>
    <Color x:Key="Theme.Accent.Pressed">#1D4ED8</Color>
    <Color x:Key="Theme.Accent.Light">#60A5FA</Color>
    <Color x:Key="Theme.Accent.Subtle10">#182563EB</Color>
    <Color x:Key="Theme.Accent.Subtle20">#302563EB</Color>
    <Color x:Key="Theme.Accent.Subtle25">#402563EB</Color>


    <!-- ── FIXED (black, white, translucent overlays) ────────────── -->
    <Color x:Key="Theme.White">#FFFFFF</Color>
    <Color x:Key="Theme.Black">#000000</Color>
    <Color x:Key="Theme.HoverOverlay">#E8E8EE</Color>
    <Color x:Key="Theme.FocusGlow50">#50000000</Color>
    <Color x:Key="Theme.FocusGlow30">#30000000</Color>
    <Color x:Key="Theme.ThumbGlow">#18000000</Color>

    <Color x:Key="Theme.Status.Success">#16A34A</Color>
    <Color x:Key="Theme.Status.Error">#DC2626</Color>

    <!-- ═══════════════════════════════════════════════════════════════
         BRUSHES — derived from the Colors above
         ═══════════════════════════════════════════════════════════════ -->

    <!-- Surface -->
    <SolidColorBrush x:Key="Theme.Brush.Surface.Darkest"  Color="{StaticResource Theme.Surface.Darkest}"/>
    <SolidColorBrush x:Key="Theme.Brush.Surface.Dark"     Color="{StaticResource Theme.Surface.Dark}"/>
    <SolidColorBrush x:Key="Theme.Brush.Surface.Mid"      Color="{StaticResource Theme.Surface.Mid}"/>
    <SolidColorBrush x:Key="Theme.Brush.Surface.Base"     Color="{StaticResource Theme.Surface.Base}"/>
    <SolidColorBrush x:Key="Theme.Brush.Surface.Raised"   Color="{StaticResource Theme.Surface.Raised}"/>
    <SolidColorBrush x:Key="Theme.Brush.Surface.Hover"    Color="{StaticResource Theme.Surface.Hover}"/>
    <SolidColorBrush x:Key="Theme.Brush.Surface.Popup"    Color="{StaticResource Theme.Surface.Popup}"/>


    <!-- Borders -->
    <SolidColorBrush x:Key="Theme.Brush.Border.Subtle"    Color="{StaticResource Theme.Border.Subtle}"/>
    <SolidColorBrush x:Key="Theme.Brush.Border.Default"   Color="{StaticResource Theme.Border.Default}"/>
    <SolidColorBrush x:Key="Theme.Brush.Border.Hover"     Color="{StaticResource Theme.Border.Hover}"/>
    <SolidColorBrush x:Key="Theme.Brush.Border.Separator" Color="{StaticResource Theme.Border.Separator}"/>

    <!-- Text -->
    <SolidColorBrush x:Key="Theme.Brush.Text.Primary"     Color="{StaticResource Theme.Text.Primary}"/>
    <SolidColorBrush x:Key="Theme.Brush.Text.Secondary"   Color="{StaticResource Theme.Text.Secondary}"/>
    <SolidColorBrush x:Key="Theme.Brush.Text.Tertiary"    Color="{StaticResource Theme.Text.Tertiary}"/>
    <SolidColorBrush x:Key="Theme.Brush.Text.Muted"       Color="{StaticResource Theme.Text.Muted}"/>
    <SolidColorBrush x:Key="Theme.Brush.Text.Placeholder" Color="{StaticResource Theme.Text.Placeholder}"/>
    <SolidColorBrush x:Key="Theme.Brush.Text.PlaceholderAlt" Color="{StaticResource Theme.Text.PlaceholderAlt}"/>

    <!-- Accent -->
    <SolidColorBrush x:Key="Theme.Brush.Accent.Base"      Color="{StaticResource Theme.Accent.Base}"/>
    <SolidColorBrush x:Key="Theme.Brush.Accent.Hover"     Color="{StaticResource Theme.Accent.Hover}"/>
    <SolidColorBrush x:Key="Theme.Brush.Accent.Pressed"   Color="{StaticResource Theme.Accent.Pressed}"/>
    <SolidColorBrush x:Key="Theme.Brush.Accent.Light"     Color="{StaticResource Theme.Accent.Light}"/>
    <SolidColorBrush x:Key="Theme.Brush.Accent.Subtle10"  Color="{StaticResource Theme.Accent.Subtle10}"/>
    <SolidColorBrush x:Key="Theme.Brush.Accent.Subtle20"  Color="{StaticResource Theme.Accent.Subtle20}"/>
    <SolidColorBrush x:Key="Theme.Brush.Accent.Subtle25"  Color="{StaticResource Theme.Accent.Subtle25}"/>

    <!-- Fixed -->
    <SolidColorBrush x:Key="Theme.Brush.White"            Color="{StaticResource Theme.White}"/>
    <SolidColorBrush x:Key="Theme.Brush.Black"            Color="{StaticResource Theme.Black}"/>
    <SolidColorBrush x:Key="Theme.Brush.HoverOverlay"     Color="{StaticResource Theme.HoverOverlay}"/>
    <SolidColorBrush x:Key="Theme.Brush.FocusGlow50"      Color="{StaticResource Theme.FocusGlow50}"/>
    <SolidColorBrush x:Key="Theme.Brush.FocusGlow30"      Color="{StaticResource Theme.FocusGlow30}"/>
    <SolidColorBrush x:Key="Theme.Brush.ThumbGlow"        Color="{StaticResource Theme.ThumbGlow}"/>

    <!-- ═══════════════════════════════════════════════════════════════
         SHAPE TOKENS
         ═══════════════════════════════════════════════════════════════ -->
    <CornerRadius x:Key="Theme.Radius.None">0</CornerRadius>
    <CornerRadius x:Key="Theme.Radius.XSmall">1</CornerRadius>
    <CornerRadius x:Key="Theme.Radius.Small">3</CornerRadius>
    <CornerRadius x:Key="Theme.Radius.Medium">4</CornerRadius>
    <CornerRadius x:Key="Theme.Radius.Large">6</CornerRadius>
    <CornerRadius x:Key="Theme.Radius.XLarge">8</CornerRadius>
    <CornerRadius x:Key="Theme.Radius.Round">9</CornerRadius>

    <Thickness x:Key="Theme.BorderThickness.Default">1</Thickness>
    <Thickness x:Key="Theme.BorderThickness.Heavy">1.5</Thickness>

    <!-- ═══════════════════════════════════════════════════════════════
         TYPOGRAPHY TOKENS
         ═══════════════════════════════════════════════════════════════ -->
    <FontFamily x:Key="Theme.Font.Family">Segoe UI</FontFamily>
    <sys:Double x:Key="Theme.Font.Size.XSmall">9</sys:Double>
    <sys:Double x:Key="Theme.Font.Size.Small">11</sys:Double>
    <sys:Double x:Key="Theme.Font.Size.Caption">12</sys:Double>
    <sys:Double x:Key="Theme.Font.Size.Body">13</sys:Double>
    <sys:Double x:Key="Theme.Font.Size.Subtitle">15</sys:Double>
    <sys:Double x:Key="Theme.Font.Size.Title">18</sys:Double>

</ResourceDictionary>
